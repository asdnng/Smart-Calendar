# Frontend environment variables
# For local development, copy this file to .env.local (which is gitignored).
# REACT_APP_ prefix is required for Create React App to expose variables to the browser.

# Backend API base URL (used by axiosSetup.js)
REACT_APP_BACKEND_API_BASE_URL=http://localhost:8080

# Google OAuth2 client ID (same value as backend GOOGLE_CLIENT_ID)
REACT_APP_GOOGLE_AUTH_CLIENT_ID=your_google_oauth2_client_id_here
